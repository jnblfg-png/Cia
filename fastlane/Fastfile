# Fastfile — Fastlane automation for ChainMark/Evidia iOS
# =========================================================
# Goal: when the owner has a Mac + Apple Developer account, shipping a build to
# pilot PIs via TestFlight is `fastlane beta` — not a multi-day manual slog.
#
# This Fastfile will NOT run on this Linux sandbox (Fastlane + Xcode are macOS
# only). It is a ready-to-run template. Read TESTFLIGHT.md for the full setup,
# the pre-submission punch list, and the one prerequisite that MUST be done
# first: there is currently NO real Xcode project (the .xcodeproj is an empty
# stub), so the project must be generated on the Mac before `beta` can build.
#
# Prerequisites (see TESTFLIGHT.md):
#   1. A real ChainMark.xcodeproj (or .xcworkspace) with a buildable app target.
#   2. fastlane/Appfile filled in (app_identifier, apple_id, team_id).
#   3. App Store Connect API key OR app-specific password provided via env vars.
#   4. Supabase live URL + anon key wired into the build (see SUPABASE punch item).

default_platform(:ios)

# Adjust these if your project/scheme names differ.
XCODEPROJ = "ChainMark.xcodeproj"
SCHEME    = "ChainMark"
OUTPUT_DIR  = "./build"
OUTPUT_NAME = "ChainMark"

platform :ios do
  before_all do
    # Fail fast with a clear message if the project hasn't been generated yet.
    unless File.exist?(XCODEPROJ) || File.exist?("ChainMark.xcworkspace")
      UI.user_error!(
        "No #{XCODEPROJ} or ChainMark.xcworkspace found. The repo ships an empty " \
        ".xcodeproj stub. Generate a real Xcode project first (see TESTFLIGHT.md, " \
        "section 'Generate the Xcode project'), then re-run."
      )
    end
  end

  desc "Build a signed release and upload to TestFlight for pilot PIs"
  lane :beta do
    # 1. Bump the build number so each upload is unique. TestFlight rejects
    #    duplicate build numbers for the same version string.
    #    increment_build_number requires the project to track build numbers;
    #    if it errors, set CURRENT_PROJECT_VERSION manually in Xcode and remove this.
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: XCODEPROJ
    )

    # 2. Sign in to App Store Connect using an API key (preferred, non-interactive,
    #    no 2FA prompt). Provide these via environment variables — NEVER commit them:
    #      ASC_KEY_ID        = the Key ID from App Store Connect
    #      ASC_ISSUER_ID     = the Issuer ID from App Store Connect
    #      ASC_KEY_CONTENT   = the contents of the .p8 file (or use key_filepath)
    #    See TESTFLIGHT.md for how to create the API key.
    if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_CONTENT"]
      app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: ENV["ASC_KEY_CONTENT"],
        is_key_content_base64: false,
        in_house: false
      )
    else
      UI.important(
        "No App Store Connect API key env vars set. Falling back to interactive " \
        "Apple ID login (you'll be prompted for 2FA). See TESTFLIGHT.md to set up " \
        "ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_CONTENT for hands-off uploads."
      )
    end

    # 3. Build the app. `gym` produces a signed .ipa.
    #    For the pilot we recommend AUTOMATIC signing managed by Xcode — simplest
    #    path. Switch export_method/signing if you later set up `match`.
    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      output_directory: OUTPUT_DIR,
      output_name: "#{OUTPUT_NAME}.ipa",
      clean: true,
      export_method: "app-store",
      # Let Xcode manage signing automatically for the pilot:
      xcargs: "-allowProvisioningUpdates"
    )

    # 4. Upload to TestFlight. skip_waiting_for_build_processing=false means the
    #    lane waits until Apple finishes processing so you know it's testable.
    upload_to_testflight(
      skip_waiting_for_build_processing: false,
      # Internal testers (your team) get the build immediately with no review.
      # For EXTERNAL testers (pilot PIs outside your org) Apple requires a short
      # Beta App Review on the first build — see TESTFLIGHT.md.
      distribute_external: false,
      notify_external_testers: false,
      changelog: ENV["TF_CHANGELOG"] || "Internal pilot build for field testing."
    )

    UI.success("Uploaded to TestFlight. Invite pilot PIs in App Store Connect → TestFlight.")
  end

  desc "Build a release .ipa locally without uploading (smoke-test the build)"
  lane :build_only do
    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      output_directory: OUTPUT_DIR,
      output_name: "#{OUTPUT_NAME}.ipa",
      clean: true,
      skip_archive: false,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates"
    )
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
    UI.message("Check TESTFLIGHT.md → Troubleshooting for common signing/build fixes.")
  end
end
