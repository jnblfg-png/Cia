# .env.example — runtime secrets for Fastlane and the app build.
# -------------------------------------------------------------
# Copy this to `fastlane/.env` (or export in your shell) and fill in real values.
# `.env` is gitignored — NEVER commit real keys.
#
# Load order: fastlane automatically reads fastlane/.env, or you can `source` this.

# --- App Store Connect API key (preferred, no 2FA prompts) ---
# Create at App Store Connect → Users and Access → Integrations → App Store Connect API.
ASC_KEY_ID=""        # e.g. "ABC123XYZ9"
ASC_ISSUER_ID=""     # e.g. "12a3b4c5-6d7e-8f90-1234-56789abcdef0"
ASC_KEY_CONTENT=""   # full contents of the AuthKey_XXXX.p8 file (PEM text)

# --- Build metadata (optional) ---
BUILD_NUMBER=""      # leave blank to auto-use a timestamp
TF_CHANGELOG="Internal pilot build for field testing."

# --- Supabase live backend (must be wired into the app build) ---
# These feed the app's Configuration.swift via the build's Info.plist / xcconfig.
# See TESTFLIGHT.md → 'Wire the live Supabase backend'.
SUPABASE_URL=""      # e.g. "https://abcdefgh.supabase.co"
SUPABASE_ANON_KEY="" # the project's anon/public key (RLS-protected, safe client-side)
